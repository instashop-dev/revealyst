# Copy to .dev.vars (gitignored). Used by `wrangler dev` / OpenNext preview.
# Neon pooled connection string — fallback until the HYPERDRIVE binding exists.
# (For the zero-credential loop use npm run dev:db and the URL it prints.)
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# Better Auth (required): 32+ char random secret, and the app's origin.
BETTER_AUTH_SECRET=generate-a-32-plus-character-random-secret
BETTER_AUTH_URL=http://localhost:8787

# GitHub OAuth (optional locally; founder registers the OAuth app).
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Paddle Billing webhook secrets (W3-M). Worker secrets in deployed envs; set
# whichever Paddle environment you point at this app's /api/webhooks/paddle. A
# request is accepted on a signature match against EITHER, so both can be set.
# PADDLE_WEBHOOK_SECRET=            # live notification-setting secret
# PADDLE_WEBHOOK_SECRET_SANDBOX=    # sandbox notification-setting secret

# Paddle Checkout + portal (W3-M PR3). ENVIRONMENT selects the API base and the
# Paddle.js environment. API_KEY is server-only; CLIENT_TOKEN is safe to expose
# to the browser. PRICE_ID / DISCOUNT_ID are the Team price + FOUNDER discount
# for the chosen environment.
# PADDLE_ENVIRONMENT=sandbox        # sandbox | production
# PADDLE_API_KEY=                   # server-side API key (never exposed)
# PADDLE_CLIENT_TOKEN=              # client-side token (Paddle.js)
# PADDLE_PRICE_ID=                  # Team price id for this environment
# PADDLE_DISCOUNT_ID=               # FOUNDER discount id for this environment
